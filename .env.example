# Convex (self-hosted)
NEXT_PUBLIC_CONVEX_URL=http://72.60.28.175:3214

# Auth
AUTH_SECRET=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-a-random-64-char-string

# RSA Keys for Convex JWT auth (base64-encoded PEM)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then: cat private.pem | base64 -w0 > private.b64 && cat public.pem | base64 -w0 > public.b64
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Email (SendGrid)
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@restaurantos.com

# KitchenHub
KITCHENHUB_API_URL=https://api.kitchenhub.com/v1
KITCHENHUB_API_KEY=...
KITCHENHUB_WEBHOOK_SECRET=...

# App URLs
ADMIN_URL=http://localhost:3005
PORTAL_URL=http://localhost:3006
PORTAL_DOMAIN=localhost:3006

# Environment
NODE_ENV=development
